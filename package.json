{
  "name": "freebird-ai",
  "displayName": "Freebird AI",
  "description": "Free, open-source AI coding assistant. Reads your codebase, edits files, and pushes to GitHub — powered by Ollama (free/local), Claude, or OpenAI. Fly free from Copilot.",
  "version": "0.2.1",
  "publisher": "TenLabs",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Adilaw12/freebird-vscode"
  },
  "homepage": "https://github.com/Adilaw12/freebird-vscode#readme",
  "bugs": {
    "url": "https://github.com/Adilaw12/freebird-vscode/issues"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["AI", "Chat", "Programming Languages", "Other"],
  "keywords": ["ai", "copilot", "ollama", "claude", "openai", "free", "chatbot", "coding assistant", "cursor", "agent"],
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "freebird.openChat",
        "title": "Freebird: Open Chat"
      },
      {
        "command": "freebird.aiCommit",
        "title": "Freebird: AI Commit"
      },
      {
        "command": "freebird.configure",
        "title": "Freebird: Configure AI Backend"
      },
      {
        "command": "freebird.inlineEdit",
        "title": "Freebird: Edit with AI"
      },
      {
        "command": "freebird.activateLicense",
        "title": "Freebird: Activate Pro License"
      },
      {
        "command": "freebird.upgradeToPro",
        "title": "Freebird: Upgrade to Pro"
      }
    ],
    "keybindings": [
      {
        "command": "freebird.openChat",
        "key": "ctrl+alt+o",
        "mac": "cmd+alt+o"
      },
      {
        "command": "freebird.inlineEdit",
        "key": "ctrl+alt+k",
        "mac": "cmd+alt+k",
        "when": "editorTextFocus && editorHasSelection"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "freebird.inlineEdit",
          "when": "editorHasSelection",
          "group": "1_modification@1"
        }
      ]
    },
    "configuration": {
      "title": "Freebird",
      "properties": {
        "freebird.backend": {
          "type": "string",
          "enum": ["ollama", "anthropic", "openai"],
          "enumDescriptions": [
            "Local AI via Ollama — completely free, runs on your machine",
            "Anthropic Claude API — pay-as-you-go, very cheap",
            "OpenAI API — pay-as-you-go"
          ],
          "default": "ollama",
          "description": "AI backend to use for Freebird"
        },
        "freebird.apiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "API key for cloud AI backends (Anthropic or OpenAI). Leave blank if using Ollama."
        },
        "freebird.model": {
          "type": "string",
          "default": "",
          "markdownDescription": "Model override. Leave blank for the recommended default per backend:\n- Ollama: `qwen2.5-coder`\n- Anthropic: `claude-haiku-4-5`\n- OpenAI: `gpt-4o-mini`"
        },
        "freebird.ollamaUrl": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Ollama server URL (only needed if Ollama runs on a non-default port)"
        },
        "freebird.licenseKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "Freebird Pro license key (format: `FB-XXXX-XXXX-XXXX-XXXX`). Get one at [freebird.tenlabs.io/upgrade](https://freebird.tenlabs.io/upgrade)."
        },
        "freebird.tabCompletion.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show inline AI code completions (ghost text) as you type."
        },
        "freebird.tabCompletion.delay": {
          "type": "number",
          "default": 350,
          "description": "Milliseconds to wait after typing stops before requesting a completion."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.4.0",
    "@vscode/vsce": "^2.24.0"
  }
}
